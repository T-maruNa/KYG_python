# ============================================================
# AI投資バトル バッチ設定 — .env.example
# このファイルをコピーして .env を作成し、値を入力してください
# ============================================================

# ------------------------------------------------------------
# OpenAI API
# ------------------------------------------------------------
OPENAI_STOCK_API_KEY=sk-...
# OPENAI_BLOG_API_KEY は未使用。将来の分離用に予約
OPENAI_BLOG_API_KEY=

# ------------------------------------------------------------
# テキスト生成プロバイダー（初期運用: openai 一本）
# ------------------------------------------------------------
TEXT_PROVIDER=openai
TEXT_MODEL=gpt-4.1-mini

# マルチプロバイダー実験フラグ（初期運用: すべて false）
ENABLE_MULTI_PROVIDER_EXPERIMENT=false
ENABLE_TEXT_FALLBACK=false
ENABLE_GOOGLE_PROVIDER=false

# Google Gemini（初期運用では使わない。将来の実験用）
# GEMINI_STOCK_API_KEY=
# GEMINI_BLOG_API_KEY=

# ------------------------------------------------------------
# データベース (PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/kyg_db

# ------------------------------------------------------------
# WordPress
# ------------------------------------------------------------
WORDPRESS_BASE_URL=https://example.com
WORDPRESS_USERNAME=wp_user
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ------------------------------------------------------------
# AI API 予算ガード
# ------------------------------------------------------------
MONTHLY_AI_BUDGET_JPY=3000
DAILY_AI_CALL_LIMIT=10
AI_RETRY_LIMIT=2

# AI呼び出し1回あたりの推定コスト（円）
ESTIMATED_COST_PER_CALL_JPY=30

# ------------------------------------------------------------
# 画像生成設定
# ------------------------------------------------------------
IMAGE_PROVIDER=openai
IMAGE_MODEL=gpt-image-1
# IMAGE_API_KEY は未設定の場合 OPENAI_STOCK_API_KEY を使用

# 初期テストでは false にしてテキスト生成を先に安定させる
ENABLE_DAILY_IMAGE_GENERATION=false
DAILY_IMAGE_GENERATION_LIMIT=5
IMAGE_RETRY_LIMIT=1

# 画像生成を有効にする場合は以下も設定
ENABLE_MORNING_SCENE_IMAGE=true
ENABLE_MORNING_SUB_SCENE_IMAGE=true
ENABLE_HERO_SCENE_IMAGE=true
ENABLE_NIGHT_REFLECTION_SCENE=true
ENABLE_HIGHLIGHT_SCENE_IMAGE=true

# ------------------------------------------------------------
# 画像アセットの本番ベースURL
# 設定時: {ASSET_BASE_URL}/characters/rei/normal.png のようにURLを組み立てる
# 未設定: プロジェクトルートの assets/ 配下を相対パスで参照する（開発・プレビュー用）
# ------------------------------------------------------------
ASSET_BASE_URL=
# 例（本番）: ASSET_BASE_URL=https://example.com/wp-content/uploads

# ------------------------------------------------------------
# 個別キャラクター固定画像URL（ASSET_BASE_URL より優先。後方互換用）
# 通常は ASSET_BASE_URL に寄せて、これらは空のままでOK
# ------------------------------------------------------------
IMG_REI=
IMG_MIRAI=
IMG_RITU=
IMG_MORNING_SCENE=
IMG_EVENING_SCENE=

# ------------------------------------------------------------
# その他
# ------------------------------------------------------------
MAX_CANDIDATES_PER_RANGE=30
ENABLE_MONTHLY_MVP_IMAGE=true

# ------------------------------------------------------------
# 土日記事投稿時刻
# ------------------------------------------------------------
SATURDAY_POST_TIME=10:00
SUNDAY_POST_TIME=10:00
